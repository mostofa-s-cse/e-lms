# Database Configuration
DATABASE_URL="mysql://username:password@localhost:3306/lms_db"

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-here"

# Server Configuration
PORT=5000
NODE_ENV=development

# Client URL (for CORS and redirects)
CLIENT_URL=http://localhost:3000
SERVER_URL=http://localhost:5000

# File Upload Configuration
MAX_FILE_SIZE=524288000 # 500MB in bytes
UPLOAD_PATH=./uploads

# SSLCommerz Configuration
SSLCOMMERZ_STORE_ID=your_store_id_here
SSLCOMMERZ_STORE_PASSWORD=your_store_password_here

# Optional: Production SSLCommerz (set to true for live payments)
# SSLCOMMERZ_IS_LIVE=false

   # Rate Limiting
   RATE_LIMIT_WINDOW_MS=900000
   RATE_LIMIT_MAX_REQUESTS=100

   
# Debugging 
DEBUG_URL="http://localhost:4000/debug"