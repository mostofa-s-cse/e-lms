// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  role      UserRole @default(STUDENT)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  profile    UserProfile?
  courses    Course[]    @relation("TeacherCourses")
  enrollments Enrollment[]
  notes      Note[]
  videos     Video[]
  quizzes    Quiz[]
  questions  Question[]
  evaluations Evaluation[]
  quizAttempts QuizAttempt[]
  evaluationsGiven Evaluation[] @relation("Evaluations")
  payments   Payment[]
  carts      Cart[]

  @@map("users")
}

model UserProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  phone           String
  address         String?
  city            String?
  state           String?
  profilePicture  String?

  // Relations
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("user_profiles")
}

model Course {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  code        String   @unique
  credits     Int      @default(0)
  price       Float?   @default(0.0)
  isFree      Boolean  @default(false)
  thumbnail   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt


  // Relations
  teacherId   String
  teacher     User       @relation("TeacherCourses", fields: [teacherId], references: [id])
  intakes     Intake[]
  notes       Note[]
  videos      Video[]
  quizzes     Quiz[]
  enrollments Enrollment[]
  cartItems   CartItem[]

  @@map("courses")
}

model Intake {
  id        String   @id @default(cuid())
  name      String
  startDate DateTime
  endDate   DateTime
  amount    Float?    @default(0.0)  // 0.0 means free course
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  courseId   String
  course     Course       @relation(fields: [courseId], references: [id])
  enrollments Enrollment[]

  @@map("intakes")
}

model Enrollment {
  id        String   @id @default(cuid())
  enrolledAt DateTime @default(now())
  status    EnrollmentStatus @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  studentId String
  student   User   @relation(fields: [studentId], references: [id])
  courseId  String
  course    Course @relation(fields: [courseId], references: [id])
  intakeId  String
  intake    Intake @relation(fields: [intakeId], references: [id])
  payments  Payment[]

  @@unique([studentId, courseId, intakeId])
  @@map("enrollments")
}

model Payment {
  id           String   @id @default(cuid())
  amount       Float
  currency     String   @default("BDT")
  status       PaymentStatus @default(PENDING)
  method       PaymentMethod @default(SSLCOMMERZ)
  referenceId  String?  @unique // SSLCommerz tran_id
  validationId String?         // SSLCommerz val_id
  gatewayUrl   String?         // URL for redirection or gateway callback
  cardType     String?         // e.g., VISA, MasterCard
  cardIssuer   String?         // e.g., City Bank
  cardBrand    String?         // e.g., Mastercard
  bankTranId   String?         // SSLCommerz bank transaction ID
  errorReason  String?         // for logging failure reasons
  paidAt       DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  userId       String
  user         User        @relation(fields: [userId], references: [id])
  enrollmentId String
  enrollment   Enrollment  @relation(fields: [enrollmentId], references: [id])

  @@map("payments")
}

model Cart {
  id        String   @id @default(cuid())
  userId    String?  // null for guest users
  sessionId String?  // for guest users
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]

  @@unique([userId, sessionId])
  @@map("carts")
}

model CartItem {
  id          String   @id @default(cuid())
  cartId      String
  courseId    String
  title       String
  price       Float
  isFree      Boolean  @default(false)
  thumbnail   String?
  teacherName String   // Store teacher name for cart items
  courseCode  String?
  intakeId    String?
  intakeName  String?
  intakeAmount Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  cart        Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  course      Course   @relation(fields: [courseId], references: [id])

  @@unique([cartId, courseId])
  @@map("cart_items")
}


model Note {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  attachment        String?
  isImage     Boolean?  @default(false)
  attachmentSize    Int?
  attachmentType    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  courseId String
  course   Course @relation(fields: [courseId], references: [id])
  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  @@map("notes")
}

model Video {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  videoUrl    String
  duration    Int      // in seconds
  thumbnail   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  courseId String
  course   Course @relation(fields: [courseId], references: [id])
  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  @@map("videos")
}

model Quiz {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  duration    Int      // in minutes
  totalMarks  Int
  passingMarks Int
  isActive    Boolean  @default(true)
  startTime   DateTime?
  endTime     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  courseId String
  course   Course @relation(fields: [courseId], references: [id])
  authorId String
  author   User   @relation(fields: [authorId], references: [id])
  questions  Question[]
  attempts   QuizAttempt[]

  @@map("quizzes")
}

model Question {
  id          String   @id @default(cuid())
  question    String   @db.Text
  type        QuestionType
  options     Json?    // For MCQ questions
  correctAnswer String  @db.Text
  marks       Int      @default(1)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  quizId String
  quiz   Quiz @relation(fields: [quizId], references: [id])
  authorId String
  author   User @relation(fields: [authorId], references: [id])
  answers    QuizAnswer[]

  @@map("questions")
}

model QuizAttempt {
  id        String   @id @default(cuid())
  score     Int
  totalMarks Int
  isPassed  Boolean
  startedAt DateTime @default(now())
  completedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  studentId String
  student   User @relation(fields: [studentId], references: [id])
  quizId    String
  quiz      Quiz @relation(fields: [quizId], references: [id])
  answers   QuizAnswer[]

  @@unique([studentId, quizId])
  @@map("quiz_attempts")
}

model QuizAnswer {
  id        String   @id @default(cuid())
  answer    String   @db.Text
  isCorrect Boolean
  marksEarned Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  attemptId String
  attempt   QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId String
  question   Question @relation(fields: [questionId], references: [id])

  @@unique([attemptId, questionId])
  @@map("quiz_answers")
}

model Evaluation {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  type        EvaluationType
  score       Float?
  maxScore    Float
  feedback    String?  @db.Text
  evaluatedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  studentId String
  student   User @relation(fields: [studentId], references: [id])
  evaluatorId String
  evaluator   User @relation("Evaluations", fields: [evaluatorId], references: [id])

  @@map("evaluations")
}

enum UserRole {
  STUDENT
  TEACHER
  ADMIN
}

enum EnrollmentStatus {
  PENDING
  ACTIVE
  COMPLETED
  DROPPED
  SUSPENDED
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
  ESSAY
}

enum EvaluationType {
  ASSIGNMENT
  PROJECT
  PRESENTATION
  PARTICIPATION
  OTHER
}
enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

enum PaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  PAYPAL
  BANK_TRANSFER
  CASH
  SSLCOMMERZ
  OTHER
}
